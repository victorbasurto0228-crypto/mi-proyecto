---
import type { ComponentNode } from '../../types/page-schema';

export interface Props {
  components: ComponentNode[];
}

const { components } = Astro.props;

const heading = components.find(c => c.type === 'heading');
const list = components.find(c => c.type === 'list');
const testimonials = (list?.children ?? []).filter(c => c.visible).sort((a, b) => a.order - b.order);
---

<section id="testimonials" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {heading && (
      <div class="text-center mb-16 text-3xl font-bold text-gray-900">
        <h2>{String(heading.value ?? '')}</h2>
      </div>
    )}
    <div class="flex flex-wrap justify-center gap-8">
      {testimonials.map(card => {
        const children = (card.children ?? []).filter(c => c.visible).sort((a, b) => a.order - b.order);
        const quote = children.find(c => c.type === 'paragraph');
        const avatar = children.find(c => c.type === 'image');
        const name = children.find(c => c.id.includes('name'));
        const role = children.find(c => c.id.includes('role'));
        const avatarImg = avatar?.value as { src: string; alt: string } | undefined;
        return (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col gap-4 w-full sm:w-72 lg:w-80">
            {quote && (
              <p class="text-gray-700 italic leading-relaxed">"{String(quote.value ?? '')}"</p>
            )}
            <div class="flex items-center gap-3 mt-auto">
              {avatarImg && (
                <img src={avatarImg.src} alt={avatarImg.alt} width={48} height={48} class="w-12 h-12 rounded-full object-cover" loading="lazy" />
              )}
              <div>
                {name && <p class="font-semibold text-gray-900">{String(name.value ?? '')}</p>}
                {role && <p class="text-sm text-gray-500">{String(role.value ?? '')}</p>}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
