---
import BaseLayout from '../layouts/BaseLayout.astro';
import TemplateRenderer from '../components/TemplateRenderer.astro';
import DefaultTemplate from '../templates/default/index.astro';
import { resolveTenantPage } from '../lib/tenant';

const tenantId = Astro.locals.tenantId;
const schema = tenantId ? await resolveTenantPage(tenantId) : null;
---

{schema ? (
  <BaseLayout seo={schema.seo} theme={schema.theme}>
    <TemplateRenderer schema={schema} />
  </BaseLayout>
) : (
  <DefaultTemplate />
)}
