---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout seo={{ title: 'LandingCraft – Build beautiful landing pages', description: 'The multi-tenant landing page platform for modern businesses.' }}>
  <header class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <span class="text-xl font-bold" style="color: var(--color-primary)">LandingCraft</span>
      <a href="/app" class="px-4 py-2 rounded-lg text-white text-sm font-semibold" style="background-color: var(--color-primary)">
        Open Editor
      </a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="py-24 bg-gradient-to-b from-indigo-50 to-white text-center">
      <div class="max-w-4xl mx-auto px-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-700 mb-6">
          🚀 Multi-tenant landing pages
        </span>
        <h1 class="text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
          Create stunning landing pages<br />for every tenant
        </h1>
        <p class="text-xl text-gray-500 mb-10 max-w-2xl mx-auto">
          A visual editor + dynamic renderer built with Astro, React, and .NET 8.
          Deploy once, power thousands of unique landing pages.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/app" class="px-8 py-4 rounded-xl text-white font-semibold text-lg shadow-lg hover:opacity-90 transition" style="background-color: var(--color-primary)">
            Open Editor
          </a>
          <a href="/?tenant=demo" class="px-8 py-4 rounded-xl font-semibold text-lg border border-gray-200 hover:bg-gray-50 transition text-gray-700">
            View Demo Tenant →
          </a>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-16">How it works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { icon: '🏗️', title: 'Multi-tenant architecture', desc: 'Each tenant gets their own branded landing page, served from a shared infrastructure.' },
            { icon: '✏️', title: 'Visual editor', desc: 'Edit content in real time with a live preview powered by the same Astro SSR renderer.' },
            { icon: '⚡', title: 'Instant updates', desc: 'Changes are saved to the API and the preview iframe reloads automatically.' },
          ].map(f => (
            <div class="bg-gray-50 rounded-2xl p-8 flex flex-col gap-4">
              <span class="text-4xl">{f.icon}</span>
              <h3 class="text-xl font-semibold text-gray-900">{f.title}</h3>
              <p class="text-gray-500">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-gray-900 text-gray-400 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      © 2024 LandingCraft. Built with Astro + React + .NET 8.
    </div>
  </footer>
</BaseLayout>
