---
import type { PageSchema } from '../types/page-schema';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageRenderer from '../components/PageRenderer.astro';

const { tenantId } = Astro.locals;
const { slug } = Astro.params;

if (!tenantId) {
  return Astro.redirect('/');
}

const pageSlug = slug || 'index';
const apiBase = import.meta.env.API_URL ?? 'http://localhost:5000';

let schema: PageSchema | null = null;

try {
  const res = await fetch(`${apiBase}/api/tenants/${tenantId}/pages/${pageSlug}`);
  if (res.ok) {
    schema = await res.json() as PageSchema;
  }
} catch (_e) {
  // API not available
}

if (!schema) {
  return new Response(
    `<!DOCTYPE html><html><head><title>Page not found</title></head><body style="font-family:sans-serif;text-align:center;padding:4rem">
      <h1>404 – Page not found</h1>
      <p>No page found for tenant <strong>${tenantId}</strong> at slug <strong>${pageSlug}</strong>.</p>
      <a href="/">← Home</a>
    </body></html>`,
    { status: 404, headers: { 'Content-Type': 'text/html' } }
  );
}
---

<BaseLayout seo={schema.seo} theme={schema.theme}>
  <PageRenderer schema={schema} />
</BaseLayout>
