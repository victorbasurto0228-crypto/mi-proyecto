---
// preview.astro – The editor iframe loads this page to show a live preview.
// Always includes PreviewListener for postMessage-based live updates from the editor.
import BaseLayout from '../layouts/BaseLayout.astro';
import TemplateRenderer from '../components/TemplateRenderer.astro';
import PreviewListener from '../components/PreviewListener.astro';
import { resolveTenantPage } from '../lib/tenant';
import { invalidateTenantCache } from '../lib/tenant';

const tenantId = Astro.locals.tenantId ?? Astro.url.searchParams.get('tenant') ?? '';

if (!tenantId) {
  return Astro.redirect('/');
}

// Invalidate cache on preview so the editor always sees fresh data after a save
invalidateTenantCache(tenantId);

const schema = await resolveTenantPage(tenantId);

if (!schema) {
  return new Response(
    `<!DOCTYPE html><html><head><title>Preview not found</title></head><body style="font-family:sans-serif;text-align:center;padding:4rem">
      <h1>Preview unavailable</h1>
      <p>No page found for tenant <strong>${tenantId}</strong>.</p>
      <p>Make sure the API is running at <code>localhost:5000</code>.</p>
      <a href="/">← Home</a>
    </body></html>`,
    { status: 404, headers: { 'Content-Type': 'text/html' } }
  );
}
---

<BaseLayout seo={schema.seo} theme={schema.theme}>
  <PreviewListener />
  <TemplateRenderer schema={schema} />
</BaseLayout>
