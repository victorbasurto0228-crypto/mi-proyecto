---
import type { Section } from '../../../types/page-schema';

export interface Props {
  section: Section;
}

const { section } = Astro.props;
const comps = section.components.filter(c => c.visible).sort((a, b) => a.order - b.order);

const heading = comps.find(c => c.type === 'heading');
const subtitle = comps.find(c => c.type === 'paragraph');
const itemsList = comps.find(c => c.type === 'list');
const items = (itemsList?.children ?? []).filter(c => c.visible).sort((a, b) => a.order - b.order);
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {heading && (
      <h2 class="text-4xl font-extrabold text-center mb-4" style="color: var(--color-text)" data-component-id={heading.id}>
        {String(heading.value ?? '')}
      </h2>
    )}
    {subtitle && (
      <p class="text-center text-gray-500 text-lg mb-16 max-w-2xl mx-auto" data-component-id={subtitle.id}>
        {String(subtitle.value ?? '')}
      </p>
    )}
    <div class="flex flex-wrap justify-center gap-8">
      {items.map(item => {
        const children = (item.children ?? []).filter(c => c.visible).sort((a, b) => a.order - b.order);
        const iconNode = children.find(c => c.type === 'icon');
        const titleNode = children.find(c => c.type === 'heading');
        const descNode = children.find(c => c.type === 'paragraph');
        return (
          <div class="bg-purple-50 rounded-2xl p-8 flex flex-col gap-4 w-full sm:w-72 lg:w-80 hover:shadow-md transition border border-purple-100">
            {iconNode && (
              <span class="text-5xl" data-component-id={iconNode.id}>{String(iconNode.value ?? '')}</span>
            )}
            {titleNode && (
              <h3 class="text-xl font-bold" style="color: var(--color-primary)" data-component-id={titleNode.id}>
                {String(titleNode.value ?? '')}
              </h3>
            )}
            {descNode && (
              <p class="text-gray-500 text-sm" data-component-id={descNode.id}>
                {String(descNode.value ?? '')}
              </p>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
