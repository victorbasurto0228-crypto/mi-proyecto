---
import type { Section } from '../../../types/page-schema';

export interface Props {
  section: Section;
}

const { section } = Astro.props;
const comps = section.components.filter(c => c.visible).sort((a, b) => a.order - b.order);

const heading = comps.find(c => c.type === 'heading');
const text = comps.find(c => c.type === 'paragraph');
const image = comps.find(c => c.type === 'image');
const img = image?.value as { src: string; alt: string; width?: number; height?: number } | undefined;
---

<section id="about" class="py-20" style="background-color: #fffdf8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center gap-16">
    {img && (
      <div class="w-full lg:w-1/2 rounded-2xl overflow-hidden shadow-lg flex-shrink-0">
        <img src={img.src} alt={img.alt} width={img.width} height={img.height}
             class="w-full h-72 lg:h-96 object-cover" loading="lazy" data-component-id={image?.id} />
      </div>
    )}
    <div class="w-full lg:w-1/2 flex flex-col gap-6">
      {heading && (
        <h2 class="text-4xl font-extrabold" style="color: var(--color-primary)" data-component-id={heading.id}>
          {String(heading.value ?? '')}
        </h2>
      )}
      {text && (
        <p class="text-gray-600 text-lg leading-relaxed" data-component-id={text.id}>
          {String(text.value ?? '')}
        </p>
      )}
    </div>
  </div>
</section>
